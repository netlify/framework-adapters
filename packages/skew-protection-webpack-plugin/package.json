{
  "name": "@netlify/skew-protection-webpack-plugin",
  "version": "0.1.0",
  "description": "Webpack plugin for enabling Netlify Skew Protection",
  "type": "module",
  "engines": {
    "node": "^20.6.1 || >=22"
  },
  "main": "./dist/main.cjs",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/main.d.cts",
        "default": "./dist/main.cjs"
      },
      "import": {
        "types": "./dist/main.d.ts",
        "default": "./dist/main.js"
      }
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "dist/**/*.d.mts"
  ],
  "scripts": {
    "build": "tsup-node",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:dev": "vitest",
    "test:ci": "vitest run",
    "dev": "tsup-node --watch",
    "publint": "npx -y publint --strict"
  },
  "keywords": [
    "netlify",
    "skew-protection",
    "webpack-plugin",
    "version-skew",
    "deploy"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/netlify/framework-adapters.git",
    "directory": "packages/skew-protection-webpack-plugin"
  },
  "bugs": {
    "url": "https://github.com/netlify/framework-adapters/issues"
  },
  "author": "Netlify Inc.",
  "peerDependencies": {
    "html-webpack-plugin": "^5.0.0",
    "webpack": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "html-webpack-plugin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsup": "^8.5.1",
    "vitest": "^4.1.9",
    "webpack": "^5.90.0"
  }
}
