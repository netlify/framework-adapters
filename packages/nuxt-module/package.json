{
  "name": "@netlify/nuxt",
  "version": "0.3.8",
  "description": "Nuxt module providing local emulation of the Netlify environment",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build prepare && nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "lint": "eslint .",
    "prepack": "npm run build",
    "publint": "npx -y publint --strict",
    "test": "exit 0",
    "test:ci": "vitest run",
    "test:dev": "vitest",
    "test:types": "vue-tsc --noEmit",
    "test:watch": "vitest watch"
  },
  "keywords": [
    "netlify",
    "nuxt",
    "nuxt-module",
    "dev"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/netlify/framework-adapters.git",
    "directory": "packages/nuxt-module"
  },
  "bugs": {
    "url": "https://github.com/netlify/framework-adapters/issues"
  },
  "author": "Netlify Inc.",
  "dependencies": {
    "@netlify/dev": "^4.18.9",
    "@netlify/dev-utils": "^4.4.6",
    "@nuxt/kit": "^4.4.8",
    "h3": "^1.15.11"
  },
  "devDependencies": {
    "@nuxt/devtools": "^2.6.2",
    "@nuxt/devtools-kit": "^2.6.2",
    "@nuxt/eslint-config": "^1.16.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "^22.18.5",
    "eslint": "^9.30.1",
    "nuxt": "^4.4.8",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
